<!DOCTYPE html>
<html lang="fr" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={Plug.CSRFProtection.get_csrf_token()} />
    <title>NexusTech — High-Tech Store</title>
    <link phx-track-static rel="stylesheet" href="/assets/app.css" />
    <script defer phx-track-static type="text/javascript" src="/assets/app.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  </head>
  <body class="bg-gray-950 text-gray-100 font-sans antialiased min-h-screen">
    <div class="flex flex-col min-h-screen">
      <header class="border-b border-gray-800 bg-gray-950/90 backdrop-blur-md sticky top-0 z-50">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
          <a href="/" class="flex items-center">
            <img src="/images/logo.png" alt="NexusTech" style="height:3.5rem;width:auto;" />
          </a>
          <div class="flex items-center gap-6">
            <a href="/" class="text-sm font-medium text-gray-400 hover:text-cyan-400 transition-colors">Produits</a>
            <a href="/customers" class="text-sm font-medium text-gray-400 hover:text-cyan-400 transition-colors">Clients</a>
          </div>
        </nav>
      </header>
      <main class="flex-1">
        <%= @inner_content %>
      </main>
      <footer class="border-t border-gray-800 bg-gray-950 py-8">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-gray-600 text-sm">
          <p class="font-mono">&copy; 2026 NexusTech — Elixir &amp; Phoenix LiveView</p>
        </div>
      </footer>
    </div>
  </body>
</html>
